#!/bin/bash
# ==========================================
# devzone-linux SETUP
# Interactive Developer Environment Installer
# OS: Linux Mint / Ubuntu
# ==========================================

# Resolve script directory for sourcing lib.sh
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_PATH="/usr/local/lib/devtools/lib.sh"

# Prefer installed lib, fall back to local
if [ -f "$LIB_PATH" ]; then
    source "$LIB_PATH"
elif [ -f "$SCRIPT_DIR/lib.sh" ]; then
    source "$SCRIPT_DIR/lib.sh"
else
    echo "❌ Cannot find lib.sh. Run install.sh first or run from the devzone-linux directory."
    exit 1
fi

root_check
get_user

separator
echo -e "${BOLD}🚀 DEVZONE-LINUX SETUP${NC}"
echo -e "${CYAN}   Developer Environment Installer${NC}"
separator

# ==========================================
# STEP 0: INSTALLER PREFERENCE
# ==========================================
log_step "STEP 0: Package Manager Preference"

ask_select "Which package manager do you prefer?" \
    "apt (native, recommended for Linux Mint)" \
    "flatpak (sandboxed, auto-updates)" \
    "snap (requires unblock on Linux Mint)"

case $SELECTED in
    0) INSTALLER="apt" ;;
    1) INSTALLER="flatpak" ;;
    2) INSTALLER="snap" ;;
esac

log_ok "Using $INSTALLER as package manager"
detect_installer || exit 1

# ==========================================
# STEP 1: CORE ESSENTIALS
# ==========================================
log_step "STEP 1: Core Essentials"

ESSENTIALS=(curl wget git unzip ca-certificates apt-transport-https gpg software-properties-common)

if ask_permission "Install core essentials (${#ESSENTIALS[@]} packages)?"; then
    apt update -qq
    apt install -y "${ESSENTIALS[@]}"
    log_ok "Core essentials installed"
fi

# ==========================================
# STEP 2: IDEs
# ==========================================
log_step "STEP 2: IDEs & Editors"

IDE_NAMES=("VS Code" "JetBrains Toolbox" "Zed" "Pulsar" "Antigravity" "Cursor")
IDE_APT=("code" "official" "official" "pulsar" "antigravity" "official")
IDE_FLATPAK=("com.visualstudio.code" "skip" "dev.zed.Zed" "dev.pulsar_edit.Pulsar" "skip" "skip")
IDE_SNAP=("code" "skip" "skip" "pulsar-edit" "skip" "skip")

# Add repos needed for apt installs
add_ide_repos() {
    if [ "$INSTALLER" != "apt" ]; then return; fi

    # VS Code
    if [ ! -f /etc/apt/sources.list.d/vscode.list ]; then
        add_apt_repo "vscode" \
            "deb [arch=amd64 signed-by=/etc/apt/keyrings/vscode.gpg] https://packages.microsoft.com/repos/code stable main" \
            "https://packages.microsoft.com/keys/microsoft.asc" \
            "vscode.gpg"
    fi

    # Pulsar
    if [ ! -f /etc/apt/sources.list.d/pulsar.list ]; then
        add_apt_repo "pulsar" \
            "deb [arch=amd64 signed-by=/etc/apt/keyrings/pulsar.gpg] https://pulsar-edit.dev/api/files/apt/ pulsar main" \
            "https://pulsar-edit.dev/api/files/pulsar.gpg" \
            "pulsar.gpg"
    fi

    # Antigravity
    if [ ! -f /etc/apt/sources.list.d/antigravity.list ]; then
        log_item "Adding Antigravity repository..."
        curl -fsSL https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/antigravity-repo-key.gpg \
            | gpg --dearmor -o /etc/apt/keyrings/antigravity-repo-key.gpg 2>/dev/null
        echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" \
            > /etc/apt/sources.list.d/antigravity.list
        apt update -qq
    fi
}

install_jetbrains_toolbox() {
    local install_dir="/opt/jetbrains-toolbox"
    local desktop_file="/usr/share/applications/jetbrains-toolbox.desktop"

    if [ -f "$install_dir/jetbrains-toolbox" ]; then
        log_item "JetBrains Toolbox already installed"
        return 0
    fi

    log_item "Downloading JetBrains Toolbox..."
    local url
    url=$(curl -s 'https://data.services.jetbrains.com/products/releases?code=TBA&latest=true&type=release' \
        | grep -oP '"linux":\{"link":"\K[^"]+' | head -1)

    if [ -z "$url" ]; then
        log_warn "Could not fetch JetBrains Toolbox download URL"
        return 1
    fi

    local tmpfile="/tmp/jetbrains-toolbox.tar.gz"
    curl -L -o "$tmpfile" "$url"
    mkdir -p "$install_dir"
    tar -xzf "$tmpfile" -C "$install_dir" --strip-components=1
    rm -f "$tmpfile"

    # Create desktop entry
    cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Name=JetBrains Toolbox
Exec=$install_dir/jetbrains-toolbox
Icon=$install_dir/jetbrains-toolbox
Type=Application
Categories=Development;
DESKTOP

    log_ok "JetBrains Toolbox installed to $install_dir"
}

install_zed_official() {
    if is_installed "zed"; then
        log_item "Zed already installed"
        return 0
    fi
    log_item "Installing Zed via official script..."
    curl -f https://zed.dev/install.sh | sh
    # Move to system-wide location
    if [ -f "$HOME/.local/bin/zed" ]; then
        cp "$HOME/.local/bin/zed" /usr/local/bin/zed
        chmod +x /usr/local/bin/zed
    fi
    log_ok "Zed installed"
}

install_cursor() {
    local install_dir="/opt/cursor"
    if [ -f "$install_dir/cursor" ]; then
        log_item "Cursor already installed"
        return 0
    fi

    log_item "Downloading Cursor..."
    local url="https://downloader.cursor.sh/linux/appImage/x64"
    local appimage="/tmp/cursor.AppImage"

    curl -L -o "$appimage" "$url"
    chmod +x "$appimage"
    mkdir -p "$install_dir"
    mv "$appimage" "$install_dir/cursor"

    # Create desktop entry
    cat > "/usr/share/applications/cursor.desktop" <<DESKTOP
[Desktop Entry]
Name=Cursor
Exec=$install_dir/cursor --no-sandbox
Icon=$install_dir/cursor
Type=Application
Categories=Development;
DESKTOP

    log_ok "Cursor installed to $install_dir"
}

if ask_permission "Install IDEs & Editors?"; then
    ask_multi "Which IDEs? (enter numbers, 0 when done)" "${IDE_NAMES[@]}"

    if [ ${#SELECTED_ITEMS[@]} -gt 0 ]; then
        add_ide_repos

        for idx in "${SELECTED_ITEMS[@]}"; do
            log_info "Installing: ${IDE_NAMES[$idx]}"

            case $idx in
                0) # VS Code
                    if [ "$INSTALLER" = "apt" ]; then
                        apt install -y code
                    else
                        install_app "VS Code" "${IDE_APT[$idx]}" "${IDE_FLATPAK[$idx]}" "${IDE_SNAP[$idx]}"
                    fi
                    ;;
                1) # JetBrains Toolbox
                    install_jetbrains_toolbox
                    ;;
                2) # Zed
                    if [ "$INSTALLER" = "flatpak" ]; then
                        install_app "Zed" "official" "dev.zed.Zed" "skip"
                    else
                        install_zed_official
                    fi
                    ;;
                3) # Pulsar
                    install_app "Pulsar" "pulsar" "dev.pulsar_edit.Pulsar" "pulsar-edit"
                    ;;
                4) # Antigravity
                    if [ "$INSTALLER" = "apt" ]; then
                        apt install -y antigravity
                    else
                        log_warn "Antigravity only available via apt"
                    fi
                    ;;
                5) # Cursor
                    install_cursor
                    ;;
            esac
        done
    fi
fi

# ==========================================
# STEP 3: CODING AGENTS
# ==========================================
log_step "STEP 3: Coding Agents"

AGENT_NAMES=("Claude Code" "Gemini CLI" "OpenCode" "KiloCode" "Codex")
AGENT_PKGS=("@anthropic-ai/claude-code" "@google/gemini-cli" "opencode-ai" "@kilocode/cli" "@openai/codex")

if ask_permission "Install coding agents?"; then
    ask_multi "Which agents? (enter numbers, 0 when done)" "${AGENT_NAMES[@]}"

    if [ ${#SELECTED_ITEMS[@]} -gt 0 ]; then
        # Ensure npm is available
        if ! command -v npm &>/dev/null; then
            log_item "npm not found, will be installed with Node.js in Step 5"
            NEED_NODEJS=true
        fi

        for idx in "${SELECTED_ITEMS[@]}"; do
            if is_installed "$(echo "${AGENT_PKGS[$idx]}" | cut -d'/' -f2)"; then
                log_item "${AGENT_NAMES[$idx]} already installed"
                continue
            fi
            log_item "Installing ${AGENT_NAMES[$idx]} via npm..."
            npm install -g "${AGENT_PKGS[$idx]}"
            log_ok "${AGENT_NAMES[$idx]} installed"
        done
    fi
fi

# ==========================================
# STEP 4: WEB SERVER
# ==========================================
log_step "STEP 4: Web Server"

ask_select "Which web server?" \
    "Apache (recommended)" \
    "Nginx" \
    "Skip"

case $SELECTED in
    0)
        WEB_SERVER="apache"
        if ! is_installed "apache2"; then
            log_item "Installing Apache..."
            apt install -y apache2
        else
            log_item "Apache already installed"
        fi

        log_item "Enabling Apache modules..."
        a2enmod rewrite proxy proxy_http ssl headers expires 2>/dev/null

        log_item "Configuring Apache..."
        # Patch apache2.conf settings
        conf="/etc/apache2/apache2.conf"
        for setting in \
            "s|^Timeout.*|Timeout 300|" \
            "s|^KeepAlive.*|KeepAlive On|" \
            "s|^MaxKeepAliveRequests.*|MaxKeepAliveRequests 100|" \
            "s|^KeepAliveTimeout.*|KeepAliveTimeout 5|"; do
            sed -i "$setting" "$conf" 2>/dev/null
        done

        # Set ServerTokens and ServerSignature in security.conf
        sec_conf="/etc/apache2/conf-available/security.conf"
        if [ -f "$sec_conf" ]; then
            sed -i 's|^ServerTokens.*|ServerTokens Prod|' "$sec_conf"
            sed -i 's|^ServerSignature.*|ServerSignature Off|' "$sec_conf"
        fi

        systemctl reload apache2
        log_ok "Apache configured and running"
        ;;
    1)
        WEB_SERVER="nginx"
        if ! is_installed "nginx"; then
            log_item "Installing Nginx..."
            apt install -y nginx
        else
            log_item "Nginx already installed"
        fi

        log_item "Configuring Nginx..."
        ng_conf="/etc/nginx/nginx.conf"
        sed -i 's|worker_processes.*|worker_processes auto;|' "$ng_conf"
        sed -i 's|keepalive_timeout.*|keepalive_timeout 65;|' "$ng_conf"

        # Add client_max_body_size if not present
        if ! grep -q "client_max_body_size" "$ng_conf"; then
            sed -i '/http {/a \    client_max_body_size 48M;' "$ng_conf"
        fi

        # Create default site config with PHP support
        cat > /etc/nginx/sites-available/default <<'NGINX'
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.php index.html index.htm;

    server_name _;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }
}
NGINX

        systemctl enable --now nginx
        systemctl reload nginx
        log_ok "Nginx configured and running"
        ;;
    2)
        log_info "Skipping web server installation"
        ;;
esac

# ==========================================
# STEP 5: PHP
# ==========================================
log_step "STEP 5: PHP"

PHP_VERSIONS=("8.0" "8.1" "8.2" "8.3" "8.4")
PHP_EXTENSIONS="cli common mysql zip gd mbstring curl xml bcmath intl soap xdebug"

# Add Ondrej PPA if not present
if [ ! -f /etc/apt/sources.list.d/ondrej-php-*.list ]; then
    log_item "Adding Ondrej PHP PPA..."
    add-apt-repository -y ppa:ondrej/php
    apt update -qq
fi

ask_multi "Which PHP versions? (multi-select, 0 when done)" "${PHP_VERSIONS[@]}"

if [ ${#SELECTED_ITEMS[@]} -gt 0 ]; then
    for idx in "${SELECTED_ITEMS[@]}"; do
        ver="${PHP_VERSIONS[$idx]}"
        log_info "Installing PHP $ver..."

        # Web server module
        if [ "$WEB_SERVER" = "apache" ]; then
            apt install -y "php${ver}" "libapache2-mod-php${ver}"
        elif [ "$WEB_SERVER" = "nginx" ]; then
            apt install -y "php${ver}" "php${ver}-fpm"
        else
            apt install -y "php${ver}"
        fi

        # Extensions
        for ext in $PHP_EXTENSIONS; do
            pkg="php${ver}-${ext}"
            apt install -y "$pkg" 2>/dev/null
        done

        log_ok "PHP $ver installed with extensions"
    done

    # Determine which PHP ini files to configure
    ask_select "Set which PHP version as default CLI?" "${PHP_VERSIONS[@]}"
    default_cli="${PHP_VERSIONS[$SELECTED]}"

    update-alternatives --set php "/usr/bin/php${default_cli}" 2>/dev/null
    log_ok "Default CLI PHP set to $default_cli"

    # Configure php.ini for all installed versions
    for idx in "${SELECTED_ITEMS[@]}"; do
        ver="${PHP_VERSIONS[$idx]}"

        # Find php.ini paths
        for sapi_dir in /etc/php/"$ver"/apache2 /etc/php/"$ver"/fpm; do
            ini="${sapi_dir}/php.ini"
            if [ -f "$ini" ]; then
                log_item "Configuring $ini"
                set_php_ini "$ini" "memory_limit" "512M"
                set_php_ini "$ini" "upload_max_filesize" "48M"
                set_php_ini "$ini" "post_max_size" "48M"
                set_php_ini "$ini" "max_execution_time" "300"
                set_php_ini "$ini" "max_input_time" "300"
                set_php_ini "$ini" "max_input_vars" "5000"
                set_php_ini "$ini" "display_errors" "Off"
                set_php_ini "$ini" "date.timezone" "UTC"
                set_php_ini "$ini" "opcache.enable" "1"
                set_php_ini "$ini" "opcache.memory_consumption" "256"
            fi
        done

        # CLI php.ini
        cli_ini="/etc/php/${ver}/cli/php.ini"
        if [ -f "$cli_ini" ]; then
            log_item "Configuring $cli_ini"
            set_php_ini "$cli_ini" "memory_limit" "-1"
            set_php_ini "$cli_ini" "display_errors" "Off"
            set_php_ini "$cli_ini" "date.timezone" "UTC"
            set_php_ini "$cli_ini" "opcache.enable" "0"
        fi
    done

    # Reload web server
    if [ "$WEB_SERVER" = "apache" ]; then
        systemctl reload apache2
    elif [ "$WEB_SERVER" = "nginx" ]; then
        # Start PHP-FPM for default version
        enable_svc "php${default_cli}-fpm"
        systemctl reload nginx
    fi

    log_ok "PHP configured"
fi

# ==========================================
# STEP 6: LANGUAGES
# ==========================================
log_step "STEP 6: Languages"

LANG_NAMES=("Node.js (upgrade to 22.x LTS)" "Python (pip, venv, dev)" "Rust (via rustup)" "Go (latest from go.dev)")
NEED_NODEJS=${NEED_NODEJS:-false}

# Offer Node.js if agents were selected and npm is missing
if $NEED_NODEJS; then
    log_info "Node.js is required for coding agents you selected"
fi

ask_multi "Which languages to install/upgrade? (0 when done)" "${LANG_NAMES[@]}"

for idx in "${SELECTED_ITEMS[@]}"; do
    case $idx in
        0) # Node.js 22.x
            log_item "Installing Node.js 22.x LTS..."
            if [ ! -f /etc/apt/sources.list.d/nodesource.list ]; then
                curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
            fi
            apt install -y nodejs
            npm install -g corepack
            log_ok "Node.js $(node -v) installed"
            ;;
        1) # Python
            log_item "Installing Python tools..."
            apt install -y python3-pip python3-venv python3-dev python3-full
            log_ok "Python $(python3 --version) with pip and venv"
            ;;
        2) # Rust
            if is_installed "rustc"; then
                log_item "Rust already installed ($(rustc --version))"
            else
                log_item "Installing Rust via rustup..."
                su - "$ACTUAL_USER" -c 'curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'
                # Add to shell profiles
                cargo_path='export PATH="$HOME/.cargo/bin:$PATH"'
                for profile in /home/"$ACTUAL_USER"/.bashrc /home/"$ACTUAL_USER"/.profile; do
                    if [ -f "$profile" ] && ! grep -q ".cargo/bin" "$profile"; then
                        echo "$cargo_path" >> "$profile"
                    fi
                done
                log_ok "Rust installed (source ~/.cargo/bin/env to use in current shell)"
            fi
            ;;
        3) # Go
            if is_installed "go"; then
                log_item "Go already installed ($(go version))"
            else
                log_item "Installing Go..."
                go_version
                go_version=$(curl -s https://go.dev/dl/?mode=json | grep -oP '"version":\s*"go\K[^"]+' | head -1)
                if [ -z "$go_version" ]; then
                    go_version="1.24.2"
                    log_warn "Could not detect latest Go version, using $go_version"
                fi
                go_tar="go${go_version}.linux-amd64.tar.gz"
                curl -L -o "/tmp/$go_tar" "https://go.dev/dl/$go_tar"
                rm -rf /usr/local/go
                tar -C /usr/local -xzf "/tmp/$go_tar"
                rm -f "/tmp/$go_tar"

                # Add to shell profiles
                go_path='export PATH=$PATH:/usr/local/go/bin'
                for profile in /home/"$ACTUAL_USER"/.bashrc /home/"$ACTUAL_USER"/.profile; do
                    if [ -f "$profile" ] && ! grep -q "/usr/local/go/bin" "$profile"; then
                        echo "$go_path" >> "$profile"
                    fi
                done
                # Also add to root's path
                export PATH=$PATH:/usr/local/go/bin
                log_ok "Go $(go version 2>/dev/null || echo "$go_version") installed"
            fi
            ;;
    esac
done

# ==========================================
# STEP 7: GIT
# ==========================================
log_step "STEP 7: Git"

if is_installed "git"; then
    log_item "Git $(git --version | awk '{print $3}') already installed"
    current_name=$(git config --global user.name 2>/dev/null)
    current_email=$(git config --global user.email 2>/dev/null)
    if [ -n "$current_name" ]; then
        log_item "Configured as: $current_name <$current_email>"
    fi
else
    log_item "Installing Git..."
    apt install -y git
fi

if ask_permission "Configure Git settings?"; then
    git_current_name=$(git config --global user.name 2>/dev/null)
    git_current_email=$(git config --global user.email 2>/dev/null)
    git_current_name="${git_current_name:-not set}"
    git_current_email="${git_current_email:-not set}"

    prompt_name=""
    printf -v prompt_name "   ${CYAN}Git user.name${NC} [${git_current_name}]: "
    read -rp "$prompt_name" git_name

    prompt_email=""
    printf -v prompt_email "   ${CYAN}Git user.email${NC} [${git_current_email}]: "
    read -rp "$prompt_email" git_email

    [ -n "$git_name" ] && su - "$ACTUAL_USER" -c "git config --global user.name '$git_name'"
    [ -n "$git_email" ] && su - "$ACTUAL_USER" -c "git config --global user.email '$git_email'"
fi

if ask_permission "Install Git extras (GitHub CLI, git-lfs, tig)?"; then
    apt install -y git-lfs tig 2>/dev/null
    # GitHub CLI
    if ! is_installed "gh"; then
        log_item "Installing GitHub CLI..."
        curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
            | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg 2>/dev/null
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
            > /etc/apt/sources.list.d/github-cli.list
        apt update -qq
        apt install -y gh
    fi
    git lfs install --system 2>/dev/null
    log_ok "Git extras installed"
fi

# ==========================================
# STEP 8: DATABASES
# ==========================================
log_step "STEP 8: Databases"

# MySQL or MariaDB
mysql_installed=false
mariadb_installed=false
systemctl is-active --quiet mysql 2>/dev/null && mysql_installed=true
systemctl is-active --quiet mariadb 2>/dev/null && mariadb_installed=true

if $mysql_installed; then
    log_item "MySQL is already installed and running"
    DB_CHOICE="mysql"
elif $mariadb_installed; then
    log_item "MariaDB is already installed and running"
    DB_CHOICE="mariadb"
else
    ask_select "MySQL and MariaDB conflict. Which one?" \
        "MySQL" \
        "MariaDB" \
        "Skip"

    case $SELECTED in
        0) DB_CHOICE="mysql" ;;
        1) DB_CHOICE="mariadb" ;;
        2) DB_CHOICE="skip" ;;
    esac
fi

case "$DB_CHOICE" in
    mysql)
        if ! $mysql_installed; then
            log_item "Installing MySQL..."
            apt install -y mysql-server
        fi
        enable_svc mysql
        ;;
    mariadb)
        if ! $mariadb_installed; then
            log_item "Installing MariaDB..."
            apt install -y mariadb-server
        fi
        enable_svc mariadb
        ;;
    skip|*)
        log_info "Skipping MySQL/MariaDB"
        ;;
esac

# PostgreSQL
if ask_permission "Install PostgreSQL?"; then
    if ! is_installed "psql"; then
        apt install -y postgresql postgresql-contrib
    else
        log_item "PostgreSQL already installed"
    fi
    enable_svc postgresql
    log_ok "PostgreSQL installed and running"
fi

# SQLite
if ! is_installed "sqlite3"; then
    if ask_permission "Install SQLite?"; then
        apt install -y sqlite3
        log_ok "SQLite installed"
    fi
else
    log_item "SQLite already installed"
fi

# Database dev user
if ask_permission "Create a development database user?"; then
    db_prompt=""
    printf -v db_prompt "   ${CYAN}Username:${NC} "
    read -rp "$db_prompt" db_user
    printf -v db_prompt "   ${CYAN}Password:${NC} "
    read -rsp "$db_prompt" db_pass
    echo ""

    if [ "$DB_CHOICE" = "mysql" ] || [ "$DB_CHOICE" = "mariadb" ]; then
        mysql -u root <<DBEOF
CREATE USER IF NOT EXISTS '${db_user}'@'localhost' IDENTIFIED BY '${db_pass}';
GRANT ALL PRIVILEGES ON *.* TO '${db_user}'@'localhost' WITH GRANT OPTION;
FLUSH PRIVILEGES;
DBEOF
        log_ok "MySQL user '$db_user' created"
    fi

    if systemctl is-active --quiet postgresql; then
        su - postgres -c "psql -c \"CREATE USER $db_user WITH PASSWORD '$db_pass' SUPERUSER;\"" 2>/dev/null
        log_ok "PostgreSQL user '$db_user' created"
    fi
fi

# ==========================================
# STEP 9: EMAIL (MAILPIT)
# ==========================================
log_step "STEP 9: Email (Mailpit)"

if is_installed "mailpit"; then
    log_item "Mailpit already installed"
else
    if ask_permission "Install Mailpit (local email testing)?"; then
        log_item "Downloading Mailpit..."
        mp_arch=$(uname -m)
        case "$mp_arch" in
            x86_64) mp_arch="amd64" ;;
            aarch64) mp_arch="arm64" ;;
        esac
        curl -sL "https://github.com/axllent/mailpit/releases/latest/download/mailpit-linux-${mp_arch}.tar.gz" \
            | tar -xz -C /usr/local/bin mailpit
        chmod +x /usr/local/bin/mailpit
        log_ok "Mailpit binary installed"
    fi
fi

if is_installed "mailpit"; then
    # Create systemd service if not present
    if [ ! -f /etc/systemd/system/mailpit.service ]; then
        cat > /etc/systemd/system/mailpit.service <<'MPUNIT'
[Unit]
Description=Mailpit Email Testing Tool
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/mailpit
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
MPUNIT
    fi
    enable_svc mailpit

    # Configure PHP sendmail if PHP is installed
    for ver_dir in /etc/php/*/; do
        ver=$(basename "$ver_dir")
        for sapi in apache2 fpm cli; do
            ini="${ver_dir}${sapi}/php.ini"
            if [ -f "$ini" ]; then
                set_php_ini "$ini" "sendmail_path" "/usr/local/bin/mailpit sendmail"
            fi
        done
    done

    log_ok "Mailpit running at http://localhost:8025"
fi

# ==========================================
# STEP 10: DATABASE ADMIN
# ==========================================
log_step "STEP 10: Database Admin UI"

if [ "$WEB_SERVER" = "none" ]; then
    log_warn "No web server installed, skipping DB admin tools"
else
    DB_ADMIN_NAMES=("AdminerEvo (~400KB, single file)" "phpMiniAdmin (~30KB, minimal)" "phpMyAdmin (~50MB, full-featured)")
    ask_multi "Which DB admin tools? (0 when done)" "${DB_ADMIN_NAMES[@]}"

    for idx in "${SELECTED_ITEMS[@]}"; do
        case $idx in
            0) # AdminerEvo
                log_item "Installing AdminerEvo..."
                adminer_dir="/var/www/html/adminer"
                mkdir -p "$adminer_dir"
                curl -sL -o "$adminer_dir/index.php" \
                    "https://github.com/adminerevo/adminerevo/releases/latest/download/adminer.php"
                chown -R "$ACTUAL_USER":www-data "$adminer_dir"
                log_ok "AdminerEvo installed at http://localhost/adminer"
                ;;
            1) # phpMiniAdmin
                log_item "Installing phpMiniAdmin..."
                pma_dir="/var/www/html/phpminiadmin"
                mkdir -p "$pma_dir"
                curl -sL -o "$pma_dir/index.php" \
                    "https://raw.githubusercontent.com/osalabs/phpminiadmin/master/phpminiadmin.php"
                chown -R "$ACTUAL_USER":www-data "$pma_dir"
                log_ok "phpMiniAdmin installed at http://localhost/phpminiadmin"
                ;;
            2) # phpMyAdmin
                log_warn "⚠️  phpMyAdmin is heavy (~50MB) and creates its own database."
                if ask_permission "Proceed with phpMyAdmin installation?"; then
                    apt install -y phpmyadmin php-mbstring php-zip php-gd php-json php-curl
                    log_ok "phpMyAdmin installed at http://localhost/phpmyadmin"
                fi
                ;;
        esac
    done
fi

# ==========================================
# STEP 11: GITEA (Self-hosted Git)
# ==========================================
log_step "STEP 11: Gitea"

if ask_permission "Install Gitea (self-hosted Git server)?"; then
    # Detect database to use
    gitea_db=""
    if $mysql_installed || [ "$DB_CHOICE" = "mysql" ]; then
        gitea_db="mysql"
    elif $mariadb_installed || [ "$DB_CHOICE" = "mariadb" ]; then
        gitea_db="mariadb"
    elif systemctl is-active --quiet postgresql; then
        gitea_db="postgres"
    fi

    if [ -z "$gitea_db" ]; then
        log_warn "No database found. Gitea requires MySQL, MariaDB, or PostgreSQL."
        log_warn "Skipping Gitea installation."
    else
        log_info "Using $gitea_db as Gitea database"

        # Create Gitea database and user
        if [ "$gitea_db" = "mysql" ] || [ "$gitea_db" = "mariadb" ]; then
            mysql -u root <<GITEADB
CREATE DATABASE IF NOT EXISTS gitea CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_unicode_ci';
CREATE USER IF NOT EXISTS 'gitea'@'localhost' IDENTIFIED BY 'gitea_local_password';
GRANT ALL PRIVILEGES ON gitea.* TO 'gitea'@'localhost';
FLUSH PRIVILEGES;
GITEADB
        elif [ "$gitea_db" = "postgres" ]; then
            su - postgres -c "psql -c \"CREATE USER gitea WITH PASSWORD 'gitea_local_password' SUPERUSER;\"" 2>/dev/null
            su - postgres -c "psql -c \"CREATE DATABASE gitea OWNER gitea ENCODING 'UTF8';\"" 2>/dev/null
        fi

        # Create git user
        if ! id -u git > /dev/null 2>&1; then
            adduser --system --shell /bin/bash --gecos 'Git Version Control' --group --disabled-password --home /home/git git
        fi

        # Download Gitea binary
        log_item "Downloading Gitea..."
        gitea_version=""
        gitea_version=$(curl -sL "https://api.github.com/repos/go-gitea/gitea/releases/latest" | grep -oP '"tag_name":\s*"v\K[^"]+')
        if [ -z "$gitea_version" ]; then
            gitea_version="1.23.6"
            log_warn "Could not fetch latest version, using $gitea_version"
        fi

        gitea_arch=$(uname -m)
        case "$gitea_arch" in
            x86_64) gitea_arch="amd64" ;;
            aarch64) gitea_arch="arm64" ;;
        esac

        gitea_url="https://dl.gitea.com/gitea/${gitea_version}/gitea-${gitea_version}-linux-${gitea_arch}"
        curl -sL -o /usr/local/bin/gitea "$gitea_url"
        chmod +x /usr/local/bin/gitea

        # Create Gitea directories
        mkdir -p /var/lib/gitea/{custom,data,log}
        chown -R git:git /var/lib/gitea/
        chmod -R 750 /var/lib/gitea/

        mkdir -p /etc/gitea
        chown root:git /etc/gitea
        chmod 770 /etc/gitea

        # Create systemd service
        cat > /etc/systemd/system/gitea.service <<'GITEAUNIT'
[Unit]
Description=Gitea (Git with a cup of tea)
After=syslog.target
After=network.target
After=mysql.service
After=mariadb.service
After=postgresql.service

[Service]
RestartSec=2s
Type=simple
User=git
Group=git
WorkingDirectory=/var/lib/gitea/
ExecStart=/usr/local/bin/gitea web --config /etc/gitea/app.ini
Restart=always
Environment=USER=git HOME=/home/git GITEA_WORK_DIR=/var/lib/gitea

[Install]
WantedBy=multi-user.target
GITEAUNIT

        systemctl daemon-reload
        systemctl enable --now gitea

        # Web server integration
        if [ "$WEB_SERVER" = "apache" ]; then
            a2enmod proxy proxy_http rewrite > /dev/null 2>&1
            cat > /etc/apache2/sites-available/gitea.test.conf <<'GITEAVHOST'
<VirtualHost *:80>
    ServerName gitea.test
    ProxyPreserveHost On
    ProxyPass / http://127.0.0.1:3000/
    ProxyPassReverse / http://127.0.0.1:3000/
</VirtualHost>
GITEAVHOST
            if ! grep -q "gitea.test" /etc/hosts; then
                echo "127.0.0.1    gitea.test" >> /etc/hosts
            fi
            a2ensite gitea.test.conf > /dev/null 2>&1
            systemctl reload apache2

        elif [ "$WEB_SERVER" = "nginx" ]; then
            cat > /etc/nginx/sites-available/gitea.test <<'GITEANGINX'
server {
    listen 80;
    listen [::]:80;
    server_name gitea.test;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
GITEANGINX
            if ! grep -q "gitea.test" /etc/hosts; then
                echo "127.0.0.1    gitea.test" >> /etc/hosts
            fi
            ln -sf /etc/nginx/sites-available/gitea.test /etc/nginx/sites-enabled/gitea.test
            systemctl reload nginx
        fi

        log_ok "Gitea installed and running at http://gitea.test:3000"
    fi
fi

# ==========================================
# STEP 12: WEB DIRECTORY PERMISSIONS
# ==========================================
log_step "STEP 12: Web Directory Permissions"

if ask_permission "Fix /var/www/html permissions?"; then
    usermod -aG www-data "$ACTUAL_USER"
    chown -R "$ACTUAL_USER":www-data /var/www/html
    find /var/www/html -type d -exec chmod 2775 {} \;
    find /var/www/html -type f -exec chmod 0664 {} \;
    log_ok "Permissions fixed for /var/www/html"
    log_warn "Log out and back in for group changes to take effect"
fi

# ==========================================
# DONE
# ==========================================
separator
echo -e "${GREEN}${BOLD}✅ SETUP COMPLETE!${NC}"
separator
echo ""
echo -e "  ${CYAN}Installed tools:${NC}"
echo -e "    Web Server:  ${BOLD}$WEB_SERVER${NC}"
echo -e "    Installer:   ${BOLD}$INSTALLER${NC}"
echo -e "    User:        ${BOLD}$ACTUAL_USER${NC}"
echo ""
echo -e "  ${CYAN}Quick commands:${NC}"
echo -e "    ${BOLD}make_vhost${NC}    — Add/delete virtual hosts"
echo -e "    ${BOLD}fix_web${NC}       — Fix web directory permissions"
echo -e "    ${BOLD}setup${NC}         — Re-run this installer"
echo ""
if is_installed "mailpit"; then
    echo -e "  ${CYAN}Services:${NC}"
    echo -e "    Mailpit UI:    ${BOLD}http://localhost:8025${NC}"
fi
echo ""
echo -e "  ${YELLOW}⚠  If you modified group permissions, log out and back in.${NC}"
separator

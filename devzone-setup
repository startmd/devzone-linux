#!/bin/bash
# ==========================================
# devzone-linux SETUP
# Interactive / CLI Developer Environment Installer
# OS: Linux Mint / Ubuntu
# ==========================================

# Resolve script directory for sourcing lib.sh
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_PATH="/usr/local/lib/devtools/lib.sh"

# Prefer installed lib, fall back to local
if [ -f "$LIB_PATH" ]; then
    source "$LIB_PATH"
elif [ -f "$SCRIPT_DIR/lib.sh" ]; then
    source "$SCRIPT_DIR/lib.sh"
else
    echo "❌ Cannot find lib.sh. Run install.sh first or run from the devzone-linux directory."
    exit 1
fi

# ==========================================
# CLI ARGUMENT VARIABLES
# ==========================================
NON_INTERACTIVE=false
CLI_INSTALLER=""
CLI_ESSENTIALS=false
CLI_IDES=()
CLI_AGENTS=()
CLI_WEB=""
CLI_PHP=()
CLI_PHP_DEFAULT=""
CLI_LANGS=()
CLI_GIT=false
CLI_GIT_NAME=""
CLI_GIT_EMAIL=""
CLI_GIT_EXTRAS=false
CLI_DB=""
CLI_POSTGRESQL=false
CLI_SQLITE=false
CLI_DB_USER=""
CLI_DB_PASS=""
CLI_MAILPIT=false
CLI_DB_ADMIN=()
CLI_GITEA=false
CLI_FIX_PERMS=false

# Shared state (set during execution)
NEED_NODEJS=false
DB_CHOICE="skip"
mysql_installed=false
mariadb_installed=false

# Constants
IDE_NAMES=("VS Code" "JetBrains Toolbox" "Zed" "Antigravity" "Cursor")
IDE_APT=("code" "official" "official" "antigravity" "official")
IDE_FLATPAK=("com.visualstudio.code" "skip" "dev.zed.Zed" "skip" "skip")
IDE_SNAP=("code" "skip" "skip" "skip" "skip")

AGENT_NAMES=("Claude Code" "Gemini CLI" "OpenCode" "KiloCode" "Codex")
AGENT_PKGS=("@anthropic-ai/claude-code" "@google/gemini-cli" "opencode-ai" "@kilocode/cli" "@openai/codex")

LANG_NAMES=("Node.js (upgrade to 22.x LTS)" "Python (pip, venv, dev)" "Rust (via rustup)" "Go (latest from go.dev)")

PHP_VERSIONS=("8.0" "8.1" "8.2" "8.3" "8.4")
PHP_EXTENSIONS="cli common mysql zip gd mbstring curl xml bcmath intl soap xdebug"

DB_ADMIN_NAMES=("AdminerEvo (~400KB, single file)" "phpMiniAdmin (~30KB, minimal)" "phpMyAdmin (~50MB, full-featured)")

# ==========================================
# HELP
# ==========================================
print_help() {
    cat <<'HELP'
Usage: devzone-setup [OPTIONS]

Run without arguments for interactive mode.

General:
  --help, -h              Show this help and exit
  --installer TYPE        Package manager: apt|flatpak|snap (default: apt)

Components:
  --essentials            Install core packages (curl, wget, git, etc.)
  --ide NAME              IDE to install (repeatable):
                            vscode|jetbrains|zed|pulsar|antigravity|cursor
  --agent NAME            Coding agent (repeatable):
                            claude|gemini|opencode|kilo|codex
  --web apache|nginx      Web server to install
  --php VER               PHP version (repeatable): 8.0|8.1|8.2|8.3|8.4
  --php-default VER       Set default CLI PHP version
  --lang NAME             Language (repeatable): nodejs|python|rust|go
  --git                   Configure git
  --git-name NAME         Git user.name
  --git-email EMAIL       Git user.email
  --git-extras            Install GitHub CLI, git-lfs, tig
  --db mysql|mariadb      MySQL or MariaDB
  --postgresql            Install PostgreSQL
  --sqlite                Install SQLite
  --db-user USER          Database dev username
  --db-pass PASS          Database dev password
  --mailpit               Install Mailpit (local email testing)
  --db-admin NAME         DB admin tool (repeatable):
                            adminer|phpminiadmin|phpmyadmin
  --gitea                 Install Gitea (self-hosted Git server)
  --fix-permissions       Fix /var/www/html permissions

Examples:
  sudo devzone-setup                                        # Interactive mode
  sudo devzone-setup --web apache --php 8.4                 # Apache + PHP 8.4
  sudo devzone-setup --web nginx --php 8.2 --php 8.4 --db mariadb
  sudo devzone-setup --ide vscode --agent claude --lang nodejs
  sudo devzone-setup --gitea --db mariadb --postgresql --web nginx
  sudo devzone-setup --essentials --web apache --php 8.4 --db mariadb --mailpit
HELP
    exit 0
}

# ==========================================
# NAME → INDEX MAPPINGS
# ==========================================
ide_name_to_idx() {
    case "$1" in
        vscode)      echo 0 ;;
        jetbrains)   echo 1 ;;
        zed)         echo 2 ;;
        antigravity) echo 3 ;;
        cursor)      echo 4 ;;
        *)
            log_err "Unknown IDE: $1"
            log_info "Valid IDEs: vscode, jetbrains, zed, antigravity, cursor"
            exit 1
            ;;
    esac
}

agent_name_to_idx() {
    case "$1" in
        claude)    echo 0 ;;
        gemini)    echo 1 ;;
        opencode)  echo 2 ;;
        kilo)      echo 3 ;;
        codex)     echo 4 ;;
        *)
            log_err "Unknown agent: $1"
            log_info "Valid agents: claude, gemini, opencode, kilo, codex"
            exit 1
            ;;
    esac
}

lang_name_to_idx() {
    case "$1" in
        nodejs) echo 0 ;;
        python) echo 1 ;;
        rust)   echo 2 ;;
        go)     echo 3 ;;
        *)
            log_err "Unknown language: $1"
            log_info "Valid languages: nodejs, python, rust, go"
            exit 1
            ;;
    esac
}

dbadmin_name_to_idx() {
    case "$1" in
        adminer)      echo 0 ;;
        phpminiadmin) echo 1 ;;
        phpmyadmin)   echo 2 ;;
        *)
            log_err "Unknown DB admin tool: $1"
            log_info "Valid tools: adminer, phpminiadmin, phpmyadmin"
            exit 1
            ;;
    esac
}

# ==========================================
# ARGUMENT PARSER
# ==========================================
parse_args() {
    if [ $# -eq 0 ]; then
        return 0
    fi

    NON_INTERACTIVE=true

    while [ $# -gt 0 ]; do
        case "$1" in
            --help|-h)
                print_help
                ;;
            --installer)
                shift
                CLI_INSTALLER="${1:-}"
                if [[ "$CLI_INSTALLER" != "apt" && "$CLI_INSTALLER" != "flatpak" && "$CLI_INSTALLER" != "snap" ]]; then
                    log_err "Invalid installer: $CLI_INSTALLER (use: apt, flatpak, snap)"
                    exit 1
                fi
                ;;
            --essentials)
                CLI_ESSENTIALS=true
                ;;
            --ide)
                shift
                CLI_IDES+=("$(ide_name_to_idx "$1")")
                ;;
            --agent)
                shift
                CLI_AGENTS+=("$(agent_name_to_idx "$1")")
                ;;
            --web)
                shift
                CLI_WEB="${1:-}"
                if [[ "$CLI_WEB" != "apache" && "$CLI_WEB" != "nginx" ]]; then
                    log_err "Invalid web server: $CLI_WEB (use: apache, nginx)"
                    exit 1
                fi
                ;;
            --php)
                shift
                ver="${1:-}"
                if [[ ! "$ver" =~ ^8\.[0-4]$ ]]; then
                    log_err "Invalid PHP version: $ver (use: 8.0, 8.1, 8.2, 8.3, 8.4)"
                    exit 1
                fi
                CLI_PHP+=("$ver")
                ;;
            --php-default)
                shift
                CLI_PHP_DEFAULT="${1:-}"
                ;;
            --lang)
                shift
                CLI_LANGS+=("$(lang_name_to_idx "$1")")
                ;;
            --git)
                CLI_GIT=true
                ;;
            --git-name)
                shift
                CLI_GIT_NAME="${1:-}"
                CLI_GIT=true
                ;;
            --git-email)
                shift
                CLI_GIT_EMAIL="${1:-}"
                CLI_GIT=true
                ;;
            --git-extras)
                CLI_GIT_EXTRAS=true
                ;;
            --db)
                shift
                CLI_DB="${1:-}"
                if [[ "$CLI_DB" != "mysql" && "$CLI_DB" != "mariadb" ]]; then
                    log_err "Invalid database: $CLI_DB (use: mysql, mariadb)"
                    exit 1
                fi
                ;;
            --postgresql)
                CLI_POSTGRESQL=true
                ;;
            --sqlite)
                CLI_SQLITE=true
                ;;
            --db-user)
                shift
                CLI_DB_USER="${1:-}"
                ;;
            --db-pass)
                shift
                CLI_DB_PASS="${1:-}"
                ;;
            --mailpit)
                CLI_MAILPIT=true
                ;;
            --db-admin)
                shift
                CLI_DB_ADMIN+=("$(dbadmin_name_to_idx "$1")")
                ;;
            --gitea)
                CLI_GITEA=true
                ;;
            --fix-permissions)
                CLI_FIX_PERMS=true
                ;;
            *)
                log_err "Unknown option: $1"
                echo ""
                log_info "Run 'devzone-setup --help' for usage."
                exit 1
                ;;
        esac
        shift
    done

    # Validate combinations
    if [ -n "$CLI_PHP_DEFAULT" ] && [ ${#CLI_PHP[@]} -eq 0 ]; then
        log_err "--php-default requires at least one --php version"
        exit 1
    fi

    if [ -n "$CLI_PHP_DEFAULT" ]; then
        local found=false
        for v in "${CLI_PHP[@]}"; do
            [ "$v" = "$CLI_PHP_DEFAULT" ] && found=true && break
        done
        if ! $found; then
            log_err "--php-default $CLI_PHP_DEFAULT not in --php versions"
            exit 1
        fi
    fi

    if { [ -n "$CLI_GIT_NAME" ] || [ -n "$CLI_GIT_EMAIL" ]; } && ! $CLI_GIT; then
        CLI_GIT=true
    fi

    if { [ -n "$CLI_DB_USER" ] || [ -n "$CLI_DB_PASS" ]; } && [ -z "$CLI_DB" ] && ! $CLI_POSTGRESQL; then
        log_warn "--db-user/--db-pass specified but no database selected"
    fi

    # Agents need npm; auto-add nodejs if not already selected
    if [ ${#CLI_AGENTS[@]} -gt 0 ]; then
        local has_nodejs=false
        for l in "${CLI_LANGS[@]}"; do
            [ "$l" = "0" ] && has_nodejs=true && break
        done
        if ! $has_nodejs; then
            CLI_LANGS+=(0)
            log_info "Node.js auto-added (required for coding agents)"
        fi
    fi

    # DB admin tools need a web server
    if [ ${#CLI_DB_ADMIN[@]} -gt 0 ] && [ -z "$CLI_WEB" ]; then
        CLI_WEB="apache"
        CLI_ESSENTIALS=true
        log_info "Apache auto-added (required for DB admin tools)"
    fi
}

# ==========================================
# HELPER FUNCTIONS (IDEs)
# ==========================================
add_ide_repos() {
    if [ "$INSTALLER" != "apt" ]; then return; fi

    if [ ! -f /etc/apt/sources.list.d/vscode.list ]; then
        add_apt_repo "vscode" \
            "deb [arch=amd64 signed-by=/etc/apt/keyrings/vscode.gpg] https://packages.microsoft.com/repos/vscode stable main" \
            "https://packages.microsoft.com/keys/microsoft.asc" \
            "vscode.gpg"
    fi

    if [ ! -f /etc/apt/sources.list.d/antigravity.list ]; then
        log_item "Adding Antigravity repository..."
        curl -fsSL --connect-timeout 10 --max-time 15 https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg \
            | gpg --dearmor -o /etc/apt/keyrings/antigravity-repo-key.gpg 2>/dev/null || true
        if [ -f /etc/apt/keyrings/antigravity-repo-key.gpg ]; then
            echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" \
                > /etc/apt/sources.list.d/antigravity.list
            apt update -qq
        else
            log_warn "Could not fetch Antigravity key, skipping repo"
        fi
    fi
}

install_jetbrains_toolbox() {
    local install_dir="/opt/jetbrains-toolbox"
    local desktop_file="/usr/share/applications/jetbrains-toolbox.desktop"

    if [ -f "$install_dir/jetbrains-toolbox" ]; then
        log_item "JetBrains Toolbox already installed"
        return 0
    fi

    log_item "Downloading JetBrains Toolbox..."
    local url
    url=$(curl -s 'https://data.services.jetbrains.com/products/releases?code=TBA&latest=true&type=release' \
        | grep -oP '"linux":\{"link":"\K[^"]+' | head -1)

    if [ -z "$url" ]; then
        log_warn "Could not fetch JetBrains Toolbox download URL"
        return 1
    fi

    local tmpfile="/tmp/jetbrains-toolbox.tar.gz"
    curl -L -o "$tmpfile" "$url"
    mkdir -p "$install_dir"
    tar -xzf "$tmpfile" -C "$install_dir" --strip-components=1
    rm -f "$tmpfile"

    cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Name=JetBrains Toolbox
Exec=$install_dir/jetbrains-toolbox
Icon=$install_dir/jetbrains-toolbox
Type=Application
Categories=Development;
DESKTOP

    log_ok "JetBrains Toolbox installed to $install_dir"
}

install_zed_official() {
    if is_installed "zed"; then
        log_item "Zed already installed"
        return 0
    fi
    log_item "Installing Zed via official script..."
    curl -f --connect-timeout 10 https://zed.dev/install.sh | sh
    if [ -f "/home/$ACTUAL_USER/.local/bin/zed" ]; then
        cp "/home/$ACTUAL_USER/.local/bin/zed" /usr/local/bin/zed
        chmod +x /usr/local/bin/zed
        chown root:root /usr/local/bin/zed
    elif [ -f "$HOME/.local/bin/zed" ]; then
        cp "$HOME/.local/bin/zed" /usr/local/bin/zed
        chmod +x /usr/local/bin/zed
        chown root:root /usr/local/bin/zed
    fi
    # Also install via flatpak if system-wide install failed
    if ! is_installed "zed" && [ "$INSTALLER" = "flatpak" ]; then
        install_app "Zed" "official" "dev.zed.Zed" "skip"
    fi
    log_ok "Zed installed"
}

install_cursor() {
    local install_dir="/opt/cursor"
    if [ -f "$install_dir/cursor" ]; then
        log_item "Cursor already installed"
        return 0
    fi

    log_item "Downloading Cursor..."
    # Official Cursor deb download URL
    local url="https://api2.cursor.sh/updates/download/golden/linux-x64-deb/cursor/3.0"
    local debfile="/tmp/cursor.deb"

    if ! curl -Lf --output "$debfile" "$url"; then
        log_err "Failed to download Cursor"
        return 1
    fi

    # Install via apt to handle dependencies
    apt install -y "$debfile"
    rm -f "$debfile"

    log_ok "Cursor installed"
}

install_one_ide() {
    local idx="$1"
    log_info "Installing: ${IDE_NAMES[$idx]}"

    case $idx in
        0) # VS Code
            if [ "$INSTALLER" = "apt" ]; then
                apt install -y code
            else
                install_app "VS Code" "${IDE_APT[$idx]}" "${IDE_FLATPAK[$idx]}" "${IDE_SNAP[$idx]}"
            fi
            ;;
        1) # JetBrains Toolbox
            install_jetbrains_toolbox
            ;;
        2) # Zed
            if [ "$INSTALLER" = "flatpak" ]; then
                install_app "Zed" "official" "dev.zed.Zed" "skip"
            else
                install_zed_official
            fi
            ;;
        3) # Pulsar
            install_app "Pulsar" "pulsar" "dev.pulsar_edit.Pulsar" "pulsar-edit"
            ;;
        4) # Antigravity
            if [ "$INSTALLER" = "apt" ]; then
                apt install -y antigravity
            else
                log_warn "Antigravity only available via apt"
            fi
            ;;
        5) # Cursor
            install_cursor
            ;;
    esac
}

install_one_agent() {
    local idx="$1"
    local agent_pkg="${AGENT_PKGS[$idx]}"
    # Extract package name from scoped pkg (e.g., @anthropic-ai/claude-code -> claude-code)
    local pkg_name
    pkg_name=$(echo "$agent_pkg" | sed 's|.*/||')
    
    if is_installed "$pkg_name"; then
        log_item "${AGENT_NAMES[$idx]} already installed"
        return
    fi
    log_item "Installing ${AGENT_NAMES[$idx]} via npm..."
    npm install -g "$agent_pkg"
    log_ok "${AGENT_NAMES[$idx]} installed"
}

install_one_php() {
    local ver="$1"
    log_info "Installing PHP $ver..."

    if [ "$WEB_SERVER" = "apache" ]; then
        apt install -y "php${ver}" "libapache2-mod-php${ver}"
    elif [ "$WEB_SERVER" = "nginx" ]; then
        apt install -y "php${ver}" "php${ver}-fpm"
    else
        apt install -y "php${ver}"
    fi

    for ext in $PHP_EXTENSIONS; do
        pkg="php${ver}-${ext}"
        apt install -y "$pkg" 2>/dev/null
    done

    log_ok "PHP $ver installed with extensions"
}

configure_php_ini() {
    local ver="$1"

    for sapi_dir in /etc/php/"$ver"/apache2 /etc/php/"$ver"/fpm; do
        ini="${sapi_dir}/php.ini"
        if [ -f "$ini" ]; then
            log_item "Configuring $ini"
            set_php_ini "$ini" "memory_limit" "512M"
            set_php_ini "$ini" "upload_max_filesize" "48M"
            set_php_ini "$ini" "post_max_size" "48M"
            set_php_ini "$ini" "max_execution_time" "300"
            set_php_ini "$ini" "max_input_time" "300"
            set_php_ini "$ini" "max_input_vars" "5000"
            set_php_ini "$ini" "display_errors" "Off"
            set_php_ini "$ini" "date.timezone" "UTC"
            set_php_ini "$ini" "opcache.enable" "1"
            set_php_ini "$ini" "opcache.memory_consumption" "256"
        fi
    done

    cli_ini="/etc/php/${ver}/cli/php.ini"
    if [ -f "$cli_ini" ]; then
        log_item "Configuring $cli_ini"
        set_php_ini "$cli_ini" "memory_limit" "-1"
        set_php_ini "$cli_ini" "display_errors" "Off"
        set_php_ini "$cli_ini" "date.timezone" "UTC"
        set_php_ini "$cli_ini" "opcache.enable" "0"
    fi
}

install_one_lang() {
    local idx="$1"
    case $idx in
        0) # Node.js 22.x
            log_item "Installing Node.js 22.x LTS..."
            if [ ! -f /etc/apt/sources.list.d/nodesource.list ]; then
                curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
            fi
            apt install -y nodejs
            npm install -g corepack
            log_ok "Node.js $(node -v) installed"
            ;;
        1) # Python
            log_item "Installing Python tools..."
            apt install -y python3-pip python3-venv python3-dev python3-full
            log_ok "Python $(python3 --version) with pip and venv"
            ;;
        2) # Rust
            if is_installed "rustc"; then
                log_item "Rust already installed ($(rustc --version))"
            else
                log_item "Installing Rust via rustup..."
                su - "$ACTUAL_USER" -c 'curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'
                cargo_path='export PATH="$HOME/.cargo/bin:$PATH"'
                for profile in /home/"$ACTUAL_USER"/.bashrc /home/"$ACTUAL_USER"/.profile; do
                    if [ -f "$profile" ] && ! grep -q ".cargo/bin" "$profile"; then
                        echo "$cargo_path" >> "$profile"
                    fi
                done
                log_ok "Rust installed (source ~/.cargo/bin/env to use in current shell)"
            fi
            ;;
        3) # Go
            if is_installed "go"; then
                log_item "Go already installed ($(go version))"
            else
                log_item "Installing Go..."
                local go_version
                go_version=$(curl -s https://go.dev/dl/?mode=json | grep -oP '"version":\s*"go\K[^"]+' | head -1)
                if [ -z "$go_version" ]; then
                    go_version="1.24.2"
                    log_warn "Could not detect latest Go version, using $go_version"
                fi
                local go_tar="go${go_version}.linux-amd64.tar.gz"
                curl -L -o "/tmp/$go_tar" "https://go.dev/dl/$go_tar"
                rm -rf /usr/local/go
                tar -C /usr/local -xzf "/tmp/$go_tar"
                rm -f "/tmp/$go_tar"

                go_path='export PATH=$PATH:/usr/local/go/bin'
                for profile in /home/"$ACTUAL_USER"/.bashrc /home/"$ACTUAL_USER"/.profile; do
                    if [ -f "$profile" ] && ! grep -q "/usr/local/go/bin" "$profile"; then
                        echo "$go_path" >> "$profile"
                    fi
                done
                export PATH=$PATH:/usr/local/go/bin
                log_ok "Go $(go version 2>/dev/null || echo "$go_version") installed"
            fi
            ;;
    esac
}

install_one_dbadmin() {
    local idx="$1"
    case $idx in
        0) # AdminerEvo
            log_item "Installing AdminerEvo..."
            local adminer_dir="/var/www/html/adminer"
            mkdir -p "$adminer_dir"
            curl -sL -o "$adminer_dir/index.php" \
                "https://github.com/adminerevo/adminerevo/releases/latest/download/adminer.php"
            chown -R "$ACTUAL_USER":www-data "$adminer_dir"
            log_ok "AdminerEvo installed at http://localhost/adminer"
            ;;
        1) # phpMiniAdmin
            log_item "Installing phpMiniAdmin..."
            local pma_dir="/var/www/html/phpminiadmin"
            mkdir -p "$pma_dir"
            curl -sL -o "$pma_dir/index.php" \
                "https://raw.githubusercontent.com/osalabs/phpminiadmin/master/phpminiadmin.php"
            chown -R "$ACTUAL_USER":www-data "$pma_dir"
            log_ok "phpMiniAdmin installed at http://localhost/phpminiadmin"
            ;;
        2) # phpMyAdmin
            if $NON_INTERACTIVE; then
                apt install -y phpmyadmin php-mbstring php-zip php-gd php-json php-curl
                log_ok "phpMyAdmin installed at http://localhost/phpmyadmin"
            else
                log_warn "⚠️  phpMyAdmin is heavy (~50MB) and creates its own database."
                if ask_permission "Proceed with phpMyAdmin installation?"; then
                    apt install -y phpmyadmin php-mbstring php-zip php-gd php-json php-curl
                    log_ok "phpMyAdmin installed at http://localhost/phpmyadmin"
                fi
            fi
            ;;
    esac
}

# ==========================================
# STEP FUNCTIONS
# ==========================================

# --- STEP 0: Installer Preference ---
step_installer() {
    log_step "STEP 0: Package Manager Preference"

    if $NON_INTERACTIVE; then
        INSTALLER="${CLI_INSTALLER:-apt}"
    else
        ask_select "Which package manager do you prefer?" \
            "apt (native, recommended for Linux Mint)" \
            "flatpak (sandboxed, auto-updates)" \
            "snap (requires unblock on Linux Mint)"

        case $SELECTED in
            0) INSTALLER="apt" ;;
            1) INSTALLER="flatpak" ;;
            2) INSTALLER="snap" ;;
        esac
    fi

    log_ok "Using $INSTALLER as package manager"
    detect_installer || exit 1
}

# --- STEP 1: Core Essentials ---
step_essentials() {
    log_step "STEP 1: Core Essentials"

    local ESSENTIALS=(curl wget git unzip ca-certificates apt-transport-https gpg software-properties-common)

    if $NON_INTERACTIVE || $CLI_ESSENTIALS; then
        apt update -qq
        apt install -y "${ESSENTIALS[@]}"
        log_ok "Core essentials installed"
    elif ! $NON_INTERACTIVE; then
        if ask_permission "Install core essentials (${#ESSENTIALS[@]} packages)?"; then
            apt update -qq
            apt install -y "${ESSENTIALS[@]}"
            log_ok "Core essentials installed"
        fi
    fi
}

# --- STEP 2: IDEs ---
step_ides() {
    log_step "STEP 2: IDEs & Editors"

    local indices=()

    if $NON_INTERACTIVE; then
        indices=("${CLI_IDES[@]}")
    else
        if ask_permission "Install IDEs & Editors?"; then
            ask_multi "Which IDEs? (enter numbers, 0 when done)" "${IDE_NAMES[@]}"
            indices=("${SELECTED_ITEMS[@]}")
        fi
    fi

    if [ ${#indices[@]} -gt 0 ]; then
        add_ide_repos
        for idx in "${indices[@]}"; do
            install_one_ide "$idx"
        done
    fi
}


# --- STEP 3: (Removed - Coding Agents moved to Step 6 for dependency reasons) -->

# --- STEP 4: Web Server ---
step_web_server() {
    log_step "STEP 4: Web Server"

    if $NON_INTERACTIVE; then

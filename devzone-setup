# --- STEP 5: PHP ---
step_php() {
    log_step "STEP 5: PHP"

    local php_indices=()

    if $NON_INTERACTIVE; then
        # CLI_PHP contains version strings like "8.2", "8.4"
        if [ ${#CLI_PHP[@]} -eq 0 ]; then
            return
        fi

        # Add Ondrej PPA
        if [ ! -f /etc/apt/sources.list.d/ondrej-php-*.list ]; then
            log_item "Adding Ondrej PHP PPA..."
            add-apt-repository -y ppa:ondrej/php
            apt update -qq
        fi

        for ver in "${CLI_PHP[@]}"; do
            install_one_php "$ver"
        done

        # Set default CLI
        local default_cli="${CLI_PHP_DEFAULT:-${CLI_PHP[0]}}"
        update-alternatives --set php "/usr/bin/php${default_cli}" 2>/dev/null
        log_ok "Default CLI PHP set to $default_cli"

        # Configure ini
        for ver in "${CLI_PHP[@]}"; do
            configure_php_ini "$ver"
        done

        # Reload web server
        if [ "$WEB_SERVER" = "apache" ]; then
            systemctl reload apache2
        elif [ "$WEB_SERVER" = "nginx" ]; then
            enable_svc "php${default_cli}-fpm"
            systemctl reload nginx
        fi

        log_ok "PHP configured"
    else
        # Add Ondrej PPA if not present
        if [ ! -f /etc/apt/sources.list.d/ondrej-php-*.list ]; then
            log_item "Adding Ondrej PHP PPA..."
            add-apt-repository -y ppa:ondrej/php
            apt update -qq
        fi

        ask_multi "Which PHP versions? (multi-select, 0 when done)" "${PHP_VERSIONS[@]}"

        if [ ${#SELECTED_ITEMS[@]} -gt 0 ]; then
            for idx in "${SELECTED_ITEMS[@]}"; do
                install_one_php "${PHP_VERSIONS[$idx]}"
            done

            ask_select "Set which PHP version as default CLI?" "${PHP_VERSIONS[@]}"
            local default_cli="${PHP_VERSIONS[$SELECTED]}"

            update-alternatives --set php "/usr/bin/php${default_cli}" 2>/dev/null
            log_ok "Default CLI PHP set to $default_cli"

            for idx in "${SELECTED_ITEMS[@]}"; do
                configure_php_ini "${PHP_VERSIONS[$idx]}"
            done

            if [ "$WEB_SERVER" = "apache" ]; then
                systemctl reload apache2
            elif [ "$WEB_SERVER" = "nginx" ]; then
                enable_svc "php${default_cli}-fpm"
                systemctl reload nginx
            fi

            log_ok "PHP configured"
        fi
    fi
}

# --- STEP 6: Languages ---
step_languages() {
    log_step "STEP 6: Languages"

    if $NEED_NODEJS; then
        log_info "Node.js is required for coding agents you selected"
    fi

    local indices=()

    if $NON_INTERACTIVE; then
        indices=("${CLI_LANGS[@]}")
    else
        ask_multi "Which languages to install/upgrade? (0 when done)" "${LANG_NAMES[@]}"
        indices=("${SELECTED_ITEMS[@]}")
    fi

    for idx in "${indices[@]}"; do
        install_one_lang "$idx"
    done

    # Deferred agent installation (agents selected before Node.js was installed)
    if $NEED_NODEJS && command -v npm &>/dev/null; then
        log_step "Coding Agents (Deferred)"
